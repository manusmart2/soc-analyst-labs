# Detection: New Administrator Account Created
# MITRE ATT&CK: T1136.001 - Create Account: Local Account
# Severity: High
# Data Source: Windows Security Event Log (Event ID 4720, 4732)

index=wineventlog (EventCode=4720 OR EventCode=4732)
| eval Account_Name=coalesce(Account_Name, TargetUserName, MemberName)
| search Account_Name="*admin*" OR EventCode=4732
| table _time, host, EventCode, Account_Name, SubjectUserName, TargetUserName
| eval severity="high"
| eval mitre_technique="T1136.001"
