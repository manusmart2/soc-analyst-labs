# Hunt: RDP Authentication Activity
# Hypothesis: Unauthorized remote desktop access indicates compromise or insider threat
# MITRE: T1021.001

index=wineventlog (EventCode=4624 Logon_Type=10) OR (EventCode=4625 Logon_Type=10)
| eval result=if(EventCode=4624, "SUCCESS", "FAILED")
| stats count BY host, Account_Name, src_ip, result
| sort -count
