# Hunt: Credential Dumping (LSASS Access)
# Hypothesis: Tools like Mimikatz access LSASS process memory
# MITRE: T1003.001

index=sysmon EventCode=10 TargetImage="*\\lsass.exe"
| stats count BY host, SourceImage, GrantedAccess
| where count >= 1
| eval suspicious=if(match(GrantedAccess, "0x1010|0x1410|0x1fffff"), "HIGH", "REVIEW")
| table host, SourceImage, GrantedAccess, count, suspicious
